{
  "manifest_version": 3,
  "name": "Quick Translator",
  "version": "1.0.65",
  "description": "Translate selected text and listen with multiple accents.",
  "permissions": [
    "storage",
    "tts",
    "offscreen"
  ],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/index.tsx"
      ]
    }
  ],
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "<all_urls>"
  ]
}